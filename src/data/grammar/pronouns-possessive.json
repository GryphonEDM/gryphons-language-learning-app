          ],
          "hint": "Черевики (shoes) is plural.",
          "explanation": "Черевики is plural, so твій → твої."
        },
        {
          "type": "matching",
          "prompt": "Match the sentence to the correct pronoun:",
          "pairs": [
            {
              "left": "___ мій телефон. (this, m.)",
