            },
            {
              "left": "___ наша вчителька. (that, f.)",
              "right": "Та"
            },
            {
              "left": "___ його діти. (these, pl.)",
              "right": "Ці"
            },
            {
              "left": "Де ___ ключі? (my, pl.)",
              "right": "мої"
            }
          ],
          "explanation": "Це мій телефон (neuter 'це' used as 'this is'); Та наша вчителька (fem.); Ці його діти (pl.); мої ключі (pl.)."
        },
        {
          "type": "sentence-order",
          "prompt": "Arrange into a correct sentence:",
          "translation": "These your books are on the table.",
          "words": [
            "Ці",
            "твої",
            "книги",
            "на",
            "столі"
          ],
          "distractors": [
            "Цей"
          ],
          "validOrders": [
            [
              "Ці",
              "твої",
              "книги",
              "на",
              "столі"
