        {
          "type": "listen-type",
          "prompt": "Listen and type what you hear:",
          "text": "Наш новий сусід дуже привітний.",
          "acceptedAnswers": [
            "Наш новий сусід дуже привітний.",
            "Наш новий сусід дуже привітний"
          ],
          "explanation": "Сусід (neighbor) is masculine, so the possessive is наш (our, masculine)."
        },
        {
          "type": "multiple-choice",
          "prompt": "Я не знаю ___ людей. (those, genitive plural)",
          "options": [
            "той",
            "ті",
            "тих"
          ],
          "correctIndex": 2,
          "explanation": "In the genitive plural (after не знаю + plural), ті → тих."
        }
      ]
    }
  ]
