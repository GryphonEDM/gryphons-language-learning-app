    {
      "sectionId": "gender-agreement",
      "title": "Gender Agreement",
      "explanation": "Ukrainian adjectives change form to agree with the gender of the noun they describe. Masculine: -ий/-ій, Feminine: -а/-я, Neuter: -е/-є. Example: великий (m.), велика (f.), велике (n.) = big.",
      "tip": "Masc: -ий/-ій | Fem: -а/-я | Neuter: -е/-є",
      "examples": [
        {
          "uk": "Великий дім.",
          "en": "A big house. (masculine)",
          "highlight": "Великий"
        },
        {
          "uk": "Велика книга.",
          "en": "A big book. (feminine)",
          "highlight": "Велика"
        },
        {
          "uk": "Велике місто.",
          "en": "A big city. (neuter)",
          "highlight": "Велике"
        }
      ],
      "exercises": [
        {
          "type": "multiple-choice",
          "prompt": "'___ кіт спить.' (small, masculine — маленький)",
          "options": [
            "Маленька",
            "Маленьке",
            "Маленький"
          ],
          "correctIndex": 2,
          "explanation": "'Кіт' is masculine, so the adjective takes the masculine form: маленький."
        },
        {
          "type": "fill-blank",
          "prompt": "___ дівчинка сміється. (beautiful, feminine — гарний)",
          "acceptedAnswers": [
            "Гарна",
            "гарна"
          ],
          "hint": "Feminine adjective ending: -а",
          "explanation": "'Дівчинка' is feminine, so use 'гарна' (feminine -а ending)."
        },
        {
          "type": "multiple-choice",
          "prompt": "'___ сонце сяє.' (bright — яскравий)",
          "options": [
            "Яскрава",
            "Яскраве",
            "Яскравий"
          ],
          "correctIndex": 1,
          "explanation": "'Сонце' is neuter, so use the neuter form: яскраве (-е ending)."
        },
        {
