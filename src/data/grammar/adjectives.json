    {
      "sectionId": "plural",
      "title": "Plural Adjectives",
      "explanation": "In the plural, adjectives have one form for all genders: -і. Example: великі будинки (big houses), великі книги (big books), великі міста (big cities). This makes plurals simpler!",
      "tip": "Plural is easy — always -і for all genders!",
      "examples": [
        {
          "uk": "Великі будинки.",
          "en": "Big houses.",
          "highlight": "Великі"
        },
        {
          "uk": "Гарні квіти.",
          "en": "Beautiful flowers.",
          "highlight": "Гарні"
        },
        {
          "uk": "Нові учні.",
          "en": "New students.",
          "highlight": "Нові"
        }
