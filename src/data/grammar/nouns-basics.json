    {
      "sectionId": "plurals",
      "title": "Forming Plurals",
      "explanation": "Common plural endings: masculine consonant nouns add -и/-і (кіт→коти, стіл→столи). Feminine -а→-и (книга→книги). Neuter -о→-а (місто→міста), -е→-я (море→моря).",
      "tip": "Masc: add -и/-і | Fem: -а→-и | Neuter: -о→-а, -е→-я",
      "examples": [
        {
          "uk": "Коти",
          "en": "Cats",
          "highlight": "Коти"
        },
        {
          "uk": "Книги",
          "en": "Books",
          "highlight": "Книги"
        },
        {
          "uk": "Міста",
          "en": "Cities",
          "highlight": "Міста"
        }
      ],
      "exercises": [
        {
