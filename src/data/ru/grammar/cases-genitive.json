    {
      "sectionId": "absence",
      "title": "Genitive for Absence (нет + genitive)",
      "explanation": "The genitive case is used with нет (there is no / there isn't) to express absence. The noun that is absent goes into the genitive case. Нет + genitive = 'there is no...'. Also used with 'у меня нет' (I don't have).",
      "tip": "нет + genitive = 'there is no...'",
      "examples": [
        {
          "ru": "Нет воды.",
          "en": "There is no water.",
          "highlight": "воды"
        },
        {
          "ru": "Нет времени.",
          "en": "There is no time.",
          "highlight": "времени"
        },
        {
          "ru": "Здесь нет магазина.",
          "en": "There is no store here.",
          "highlight": "магазина"
        }
      ],
