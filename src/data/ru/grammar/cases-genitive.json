      "sectionId": "numbers",
      "title": "Genitive with Numbers",
      "explanation": "Numbers affect the case of the noun: 1 = nominative singular; 2, 3, 4 = genitive singular; 5-20 and compound numbers ending in 5-9, 0 = genitive plural. This is one of the trickiest parts of Russian grammar.",
      "tip": "1 = nom. sg. | 2-4 = gen. sg. | 5+ = gen. pl.",
      "examples": [
        {
          "ru": "Одна книга.",
          "en": "One book. (nominative)",
          "highlight": "книга"
        },
        {
          "ru": "Две книги.",
          "en": "Two books. (genitive singular)",
          "highlight": "книги"
        },
        {
          "ru": "Пять книг.",
          "en": "Five books. (genitive plural)",
          "highlight": "книг"
        }
