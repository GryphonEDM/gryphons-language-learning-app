    {
      "sectionId": "possession",
      "title": "Genitive for Possession",
      "explanation": "The genitive case answers 'whose?' (чей? чья? чьё?). It shows that something belongs to someone or something. Masculine nouns ending in a consonant add -а or -у. Feminine nouns change -а to -ы/-и. Neuter nouns change -о to -а, -е to -я.",
      "tip": "Masc: add -а | Fem: -а→-ы/-и | Neuter: -о→-а",
      "examples": [
        {
          "ru": "Это книга мамы.",
          "en": "This is mom's book.",
          "highlight": "мамы"
        },
        {
          "ru": "Машина папы.",
          "en": "Dad's car.",
          "highlight": "папы"
        },
        {
          "ru": "Центр города.",
          "en": "The center of the city.",
          "highlight": "города"
        }
      ],
      "exercises": [
        {
          "type": "multiple-choice",
          "prompt": "Чья это сумка? (сестра)",
          "options": [
            "сестру",
            "сестрой",
            "сестры"
          ],
          "correctIndex": 2,
          "explanation": "Feminine nouns ending in -а change to -ы in the genitive: сестра → сестры."
        },
        {
          "type": "fill-blank",
          "prompt": "Это телефон ___. (брат)",
