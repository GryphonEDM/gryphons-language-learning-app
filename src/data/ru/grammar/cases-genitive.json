          "prompt": "Put the word in the genitive case: 'Это дом ___.' (мама)",
          "acceptedAnswers": [
            "мамы"
          ],
          "hint": "-а → -ы",
          "explanation": "Мама → мамы. Feminine nouns ending in -а change to -ы in the genitive."
        },
