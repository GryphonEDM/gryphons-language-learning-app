    {
      "sectionId": "gender-agreement",
      "title": "Gender Agreement",
      "explanation": "Russian adjectives change form to agree with the gender of the noun they describe. Masculine: -ый/-ий/-ой, Feminine: -ая/-яя, Neuter: -ое/-ее. Example: большой (m.), большая (f.), большое (n.) = big.",
      "tip": "Masc: -ый/-ий/-ой | Fem: -ая/-яя | Neuter: -ое/-ее",
      "examples": [
        {
          "ru": "Большой дом.",
          "en": "A big house. (masculine)",
          "highlight": "Большой"
        },
        {
          "ru": "Большая книга.",
          "en": "A big book. (feminine)",
          "highlight": "Большая"
        },
        {
          "ru": "Большое окно.",
          "en": "A big window. (neuter)",
          "highlight": "Большое"
        }
      ],
      "exercises": [
